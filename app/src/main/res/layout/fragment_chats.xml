<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7FBFF"
    tools:context=".ChatsFragment">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B3E5FC"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_horizontal"
        android:padding="20dp"
        android:text="My chats"
        android:textColor="#455A64"
        android:textSize="24sp" />

    <ListView
        android:id="@+id/chatsListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E1F5FE"
        android:dividerHeight="1dp"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp">

        <Button
            android:id="@+id/aiChatBtn"
            android:layout_width="226dp"
            android:layout_height="wrap_content"
            android:backgroundTint="#8DEBC7"
            android:elevation="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text=" AI chat"
            android:textAllCaps="false"
            android:textColor="#F4F4F1"
            android:textSize="18sp" />

    </LinearLayout>

</LinearLayout>